<div class="container">
<div class="leftpro next-prevb">
<div class="heading"><h1><span>{{popular_title}}</span></h1></div>
<div class="row rless">
  <div id="popular" class="owl-theme owl-carousel">

     {% set temp = 0 %}
    {% set setCol = 2 %}
 {% for product in products %}
  {% set temp = temp + 1 %}

        {% if temp % setCol == 1 %}
            <div class="multi-row">
        {% endif %}
<!-- writ code Here -->
  <div class="product-layout col-xs-12 cless">
    <div class="product-thumb transition">
      <div class="image col-xs-5">
        <div class="leftimg">
        <a href="{{ product.href }}"><img src="{{ product.thumb }}" alt="{{ product.name }}" title="{{ product.name }}" class="img-responsive center-block" /></a>
          <!-- Webiarch Images Start -->
                 {% set t = 0 %}
                  {% for more_image in product.more_images %}
                  {% for pop in more_image %}
                  {% if t == 0 %}
                    <a href="{{ product.href }}"><img src="{{ pop.popup_more }}" class="img-responsive second-img" alt="hover image"/></a>
                  {% set t = t + 1 %}
                    {% endif %}

                  {% endfor %}
                  {% endfor %}
          <!-- End -->
        {% if product.tag_per  %}
        <span class="sale">{{ product.tag_per }}%</span>
        {% endif %} 
        </div>
      </div>
      <div class="caption col-xs-7 text-left">
        {# <span class="probrand">{{ product.manufacturer }}</span> #}
        
         

          
        <h4  class="protitle"><a href="{{ product.href }}">{{ product.name }}</a></h4>
        {% if product.rating %}
          <div class="rating">
            {% for i in 1..5 %}
            {% if product.rating < i %}
            <span class="fa fa-stack">
              <i class="fa fa-star-o fa-stack-2x"></i>
            </span>
            {% else %}
            <span class="fa fa-stack">
              <i class="fa fa-star fa-stack-2x"></i><i class="fa fa-star-o fa-stack-2x"></i>
            </span>
            {% endif %}
          {% endfor %}</div>{% else %}
          <div class="rating">{% for i in 1..5 %}
          <span class="fa fa-stack"><i class="fa fa-star-o fa-stack-2x"></i></span>
          {% endfor %}</div>
        {% endif %}
         {% if product.price %}
        <div class="price">
          {% if not product.special %}
          {{ product.price }}
          {% else %}
          <span class="price-new">{{ product.special }}</span> <span class="price-old">{{ product.price }}</span>
          {% endif %}
         {#  {% if product.tax %}
          <span class="price-tax">{{ text_tax }} {{ product.tax }}</span>
          {% endif %} #}
        </div>
        {% endif %}
 
       

       <div class="button-group">
            <div class="absbtn">
             <button type="button"  data-toggle="tooltip" title="{{ button_cart }}" onclick="cart.add('{{ product.product_id }}');"><svg><use xlink:href="#pcart"></use></svg></button>
            <button type="button" data-toggle="tooltip" title="{{ button_wishlist }}" onclick="wishlist.add('{{ product.product_id }}');"><svg><use xlink:href="#heart" /></svg></button>
            <button type="button" data-toggle="tooltip" title="{{ button_compare }}" onclick="compare.add('{{ product.product_id }}');"><svg><use xlink:href="#compare"/></svg></button>
            <div data-toggle="tooltip" title="Quickview"  class="bquickv"></div>
           </div>
      </div>
      {# winter infotech countdown start #}
                {% if product.special and product.end_date  != 0 %}
                  <div class="wbtimer">
                  <div claas="wb_countdown">
                    <div data-date="{{ product.end_date }}" class="wb_product_countdown">
                      <div class="product_count wb_countdown_days">
                        <span class="wb_countdown_days_digit"></span>
                        <p>{{ count_day }}</p>
                      </div>
                      <div class="product_count wb_countdown_hours">
                        <span class="wb_countdown_hours_digit"></span>
                        <p>{{ count_hour }}</p>
                      </div>
                      <div class="product_count wb_countdown_minutes">
                        <span class="wb_countdown_minutes_digit"></span>
                        <p>{{ count_min }}</p>
                      </div>
                      <div class="product_count wb_countdown_seconds">
                        <span class="wb_countdown_seconds_digit"></span>
                        <p>{{ count_sec }}</p>
                      </div>
                    </div>
                  </div>
                  </div>
                {% endif %}
                {# winter infotech countdown End #}
      </div>

    </div>
  </div>
<!-- writ code Here End -->
 {% if temp % setCol == 0 %}
                </div>
            {% endif %}

      {% endfor %}

      {% if products|length % setCol != 0 %}
            </div>
      {% endif %}
</div>
  </div>
</div>
</div>



<script type="text/javascript">
    $(document).ready(function() {
    $("#popular").owlCarousel({
    itemsCustom : [
    [0, 1],
    [600, 2],
    [768, 2],
    [992, 2],
    [1200, 3],
    [1410, 3],
    [1590, 4]
    ],
      // autoPlay: 1000,
      navigationText: ['<i class="fa fa-angle-left" aria-hidden="true"></i>', '<i class="fa fa-angle-right" aria-hidden="true"></i>'],
      navigation : true,
      pagination:false
    });
    });
</script>
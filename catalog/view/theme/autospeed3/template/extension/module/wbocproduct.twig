<div class="container">
<div class="hometimer next-prevb ">
<div class="timerpro leftpro">
<h1 class="heading text-center"><span>{{ oc_title }}</span></h1>
<div class="row rless"> 
<div class="">
  <div id="count" class="owl-theme owl-carousel">
  {% for product in products %}
  <div class="product-layout col-xs-12 cless">
    <div class="product-thumb transition">
      <div class="image">
        <div class="oc_bor">
        <a href="{{ product.href }}"><img src="{{ product.thumb }}" alt="{{ product.name }}" title="{{ product.name }}" class="img-responsive center-block js-product-cover" /></a>

         {% if product.is_new %}<span class="new">{{ pro_new }}</span>{% endif %}

         

        {% if product.price %}
          {% if product.special %}
            {#  <span class="reduce-price">{{ pro_sale }}</span> #}
          {% endif %}
      {% endif %}
    </div>
        
     
         <div class="all-timer">
          {% if config_module.countdown %}<div id="Countdown{{ product.product_id }}" class="box-timer"></div> {% endif %}
         {# <div id="Countdown42" class="box-timer is-countdown"><span class="countdown-row countdown-show4 "><span class="countdown-section"><span class="countdown-amount">758</span><span class="countdown-period">D</span></span><span class="countdown-section"><span class="countdown-amount">8</span><span class="countdown-period">H</span></span><span class="countdown-section"><span class="countdown-amount">21</span><span class="countdown-period">M</span></span><span class="countdown-section"><span class="countdown-amount">30</span><span class="countdown-period">S</span></span></span></div> #}  
      </div>
      </div>
     
           
      <div class="caption text-center">
        <div class="caption-bor">
        <h4 class="protitle"><a href="{{ product.href }}">{{ product.name }}</a></h4>
          {% if product.rating %}
          <div class="rating">
            {% for i in 1..5 %}
            {% if product.rating < i %}
            <span class="fa fa-stack">
              <i class="fa fa-star-o fa-stack-2x"></i>
            </span>
            {% else %}
            <span class="fa fa-stack">
              <i class="fa fa-star fa-stack-2x"></i><i class="fa fa-star-o fa-stack-2x"></i>
            </span>
            {% endif %}
          {% endfor %}</div>{% else %}
          <div class="rating">{% for i in 1..5 %}
          <span class="fa fa-stack"><i class="fa fa-star-o fa-stack-2x"></i></span>
          {% endfor %}</div>
        {% endif %} 
         {% if product.price %}
        <div class="price">
          {% if not product.special %}
          {{ product.price }}
          {% else %}
          <span class="price-new">{{ product.special }}</span> <span class="price-old">{{ product.price }}</span>
          {% endif %}
         {#  {% if product.tax %}
          <span class="price-tax">{{ text_tax }} {{ product.tax }}</span>
          {% endif %} #}
        </div>
        {% endif %}{% if product.tag_per  %}
        <span class="sale">{{ product.tag_per }}%</span>
        {% endif %} 
         {# <p class="countprice">{{ product.description }}</p> #} 
      </div>
       <div class="button-group">
            <div class="absbtn">
         <button type="button" class="cartb" data-toggle="tooltip" title="{{ button_cart }}" onclick="cart.add('{{ product.product_id }}');"><svg><use xlink:href="#pcart"></use></svg><span class="hidden-xs hidden-sm">{{ button_cart }}</span></button>
          </div>
            <div class="add-cart">
          <button type="button" data-toggle="tooltip" title="{{ button_wishlist }}" onclick="wishlist.add('{{ product.product_id }}');"><svg><use xlink:href="#heart" /></svg></button>
        
          <button type="button" data-toggle="tooltip" title="{{ button_compare }}" onclick="compare.add('{{ product.product_id }}');"><svg><use xlink:href="#compare"/></svg></button>
           <div data-toggle="tooltip" title="Quickview"  class="bquickv"></div>
           </div>
          
      </div>
     
        
      {# wbstock bar #}
        <div class="quantity-progress" >
         
         <span class="time-stock">{{ text_stock }}</span><span class="time-qua">{{ product.quantity }}</span>
                  {% if stock == "In Stock" %}
                    <span class="bg-success">
                  {% elseif stock == "Pre-Order" %}
                    <span class="bg-danger">
                  {% elseif stock == "2-3 Days" %}
                    <span class="bg-warning">
                  {% else %}
                    <span class="bg-red">
                  {% endif %}{{ stock }}
                    </span>
        </div>
      {# stock bar #}
      </div>

       
    

   {% if product.date_end %}
            <script type="text/javascript">
                (function($){
                    $('#Countdown{{ product.product_id }}').countdown({
                        until: new Date({{ product.date_end|date("Y") }}, {{ product.date_end|date("m") }}-1, {{ product.date_end|date("d") }}, {{ product.date_end|date("H") }}, {{ product.date_end|date("i") }}, {{ product.date_end|date("s") }}),
                        labels: ['Years', 'Months', 'Weeks', 'D', 'H', 'M', 'S'],
                        labels1: ['Year', 'Month', 'Week', 'Day', 'Hr', 'Min', 'Sec'],
                    });
                    //$('#Countdown<?php echo $product['product_id'];?>').countdown('pause');
               }(jQuery));
            </script>
            {% endif %}
            </div>
    </div>
  {% endfor %}


  
   </div>
</div>
 </div>
</div>
</div>
</div>

<script type="text/javascript">
    $(document).ready(function() {
    $("#count").owlCarousel({
    itemsCustom : [
    [0, 1],
    [576, 2],
    [768, 2],
    [992, 3],
    [1200, 4],
    [1410, 4],
    [1590, 5]
    ],
      // autoPlay: 1000,
      navigationText: ['<i class="fa fa-angle-left" aria-hidden="true"></i>', '<i class="fa fa-angle-right" aria-hidden="true"></i>'],
      navigation : true,
      pagination: false
    });
     });

    
</script>



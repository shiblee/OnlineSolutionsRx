<div class="container toppad">
<div class="row">
<div class="col-lg-6 col-md-12 col-xs-12 toppro next-prevb">
<div class="topbor">
<div class="heading"><h1><span>{{popular_title}}</span></h1></div>
<div class="row rless">
  <div id="toprate" class="owl-theme owl-carousel">

 {% for product in products %}
    <div class="multi-row">
<!-- writ code Here -->
  <div class="product-layout col-xs-12 cless">
    <div class="product-thumb transition">
      
          <div class="toppro-ri">
      <div class="image col-lg-6 col-md-6 col-sm-6 col-xs-6">
        <div class="leftimg">
        <a href="{{ product.href }}"><img src="{{ product.thumb }}" alt="{{ product.name }}" title="{{ product.name }}" class="img-responsive center-block js-product-cover" /></a>
          <!-- Webiarch Images Start -->
                 {% set t = 0 %}
                  {% for more_image in product.more_images %}
                  {% for pop in more_image %}
                  {% if t == 0 %}
                    <a href="{{ product.href }}"><img src="{{ pop.popup_more }}" class="img-responsive second-img js-product-cover" alt="hover image"/></a>
                  {% set t = t + 1 %}
                    {% endif %}

                  {% endfor %}
                  {% endfor %}
          <!-- End -->
       {# {% if product.tag_per  %}
        <span class="sale">{{ product.tag_per }}%</span>
        {% endif %} #}
        </div>
         
      </div>
     
      <div class="caption  col-lg-6 col-md-6 col-sm-6 col-xs-6  text-left">
        {# <span class="probrand">{{ product.manufacturer }}</span> #}
        
         
      
          
        <div class="bran">
                <span><a href="{{ product.manufacturer_id }}" class="textdeb">{{ product.manufacturer }}</a></span>
        </div>
        <h4  class="protitle"><a href="{{ product.href }}">{{ product.name }}</a></h4>
        <p class="countprice">{{ product.description }}</p>
        {% if product.rating %}
          <div class="rating">
            {% for i in 1..5 %}
            {% if product.rating < i %}
            <span class="fa fa-stack">
              <i class="fa fa-star-o fa-stack-2x"></i>
            </span>
            {% else %}
            <span class="fa fa-stack">
              <i class="fa fa-star fa-stack-2x"></i><i class="fa fa-star-o fa-stack-2x"></i>
            </span>
            {% endif %}
          {% endfor %}</div>{% else %}
          <div class="rating">{% for i in 1..5 %}
          <span class="fa fa-stack"><i class="fa fa-star-o fa-stack-2x"></i></span>
          {% endfor %}</div>
        {% endif %}
         {# Winter Infotech -- Add Code Data update #}
        {% if product.price %}
          {# Start Discount Code #}
           {# <p class="discount">
            {% if product.discount %}
              <span data-update='discount-{{ product.product_id }}'>{{ product.discount }}</span>
            {% endif %}
          </p> #}
          {# End Discount Code #}
          <p class="price">
            {% if not product.special %}
            <span data-update='price-{{ product.product_id }}' class="price">{{ product.price }}</span>
            {% else %}
            <span data-update='price-new-{{ product.product_id }}' class="price-new">{{ product.special }}</span> <span data-update='price-{{ product.product_id }}' class="price-old">{{ product.price }}</span>
            {% endif %}
           
          </p>
        {# Winter Infotech -- Add Code Data update end #}
        {% endif %}
      
       

       <div class="button-group">
        <div class="topbt">
          {% if product.options %}
           <input type="hidden" name="product_id" value="{{ product.product_id }}"/>
            <button type="button" class="webi-cart cartb" ><svg class="hidden-lg  hidden-md"><use xlink:href="#hcart"></use></svg><span class="hidden-xs hidden-sm">{{ button_cart }}</span>
             </button>
             {% else %}
             <button type="button" onclick="cart.add('{{ product.product_id }}');"><svg><use xlink:href="#hcart"></use></svg><span class="hidden-xs hidden-sm hidden-md">{{ button_cart }}</span>
               </button>
               {% endif %}
                 <input type="hidden" name="hid-qty-msg" value="{{ atleast_cart }}">
          <button type="button" data-toggle="tooltip" title="{{ button_wishlist }}" onclick="wishlist.add('{{ product.product_id }}');"><svg><use xlink:href="#heart" /></svg></button>
          <button type="button" data-toggle="tooltip" title="{{ button_compare }}" onclick="compare.add('{{ product.product_id }}');"><svg><use xlink:href="#compare"/></svg></button>
          <div data-toggle="tooltip" title="Quickview"  class="bquickv"></div>
     </div>
         </div> 
         {# wbstock bar #}
        <div class="quantity-progress" >
          <div class="product-available text-left">{{ text_availabe }}<span>{{ product.quantity }}</span></div>
          {# stock bar #}
            <div class="obar d-inline-block">
              {% if product.quantity <= 50 %}
                <div class="ibar bar1"></div>
              {% elseif product.quantity <= 350 %}
                <div class="ibar bar2"></div>
              {% elseif product.quantity <= 650 %}
                <div class="ibar bar3"></div>
              {% elseif product.quantity <= 1000 %}
                <div class="ibar bar4"></div>
              {% else %}
                <div class="ibar bar5"></div>
              {% endif %}
            </div>
          {# wbstock bar #}
        </div>
      {# stock bar #}
      </div>
       </div>


    </div>
    
  </div>
<!-- writ code Here End -->
 </div>
    {% endfor %}
</div>
  </div>
</div>
</div>



<script type="text/javascript">
    $(document).ready(function() {
    $("#toprate").owlCarousel({
    itemsCustom : [
    [0, 1],
    [600, 1],
    [768, 1],
    [992, 1],
    [1200, 1],
    [1410, 1],
    [1590, 1]
    ],
      // autoPlay: 1000,
      navigationText: ['<i class="fa fa-angle-left" aria-hidden="true"></i>', '<i class="fa fa-angle-right" aria-hidden="true"></i>'],
      navigation : true,
      pagination:false
    });
    });
</script>

